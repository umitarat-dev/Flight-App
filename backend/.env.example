# Core
SECRET_KEY=change-me
ENV_NAME=prod
DEBUG=False
DJANGO_LOG_LEVEL=INFO

# Backend host/security
ALLOWED_HOSTS=your-backend-domain.onrender.com
CSRF_TRUSTED_ORIGINS=https://your-backend-domain.onrender.com,https://your-frontend-domain.onrender.com
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.onrender.com

# PostgreSQL (Neon/Render/Supabase etc.)
SQL_DATABASE=flight_app
SQL_USER=your_db_user
SQL_PASSWORD=your_db_password
SQL_HOST=your-db-host
SQL_PORT=5432
