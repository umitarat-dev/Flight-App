# ====================================================================
# GENERAL / IDE / OS Junk
# ====================================================================
.DS_Store
*.log
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
**/.env

# ====================================================================
# BACKEND (Django)
# ====================================================================
backend/__pycache__/
backend/*.py[cod]
backend/*$py.class
backend/*.mo
backend/*.pot
backend/staticfiles/
backend/media/
backend/db.sqlite3
**/db.sqlite3
backend/db.sqlite3-journal
backend/env*/
backend/venv*/
backend/.venv/
backend/pip-log.txt
backend/debug.log

# ====================================================================
# FRONTEND (React / Vite)
# ====================================================================
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.local
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local


# ====================================================================
# ENV & SECRETS (Safety First!)
# ====================================================================
# Tüm .env dosyalarını genel olarak engelle
**/.env
**/.env.*

# Örnek dosyaların git'e gitmesine izin ver
!**.env.example
!frontend/.env.production.example

# ====================================================================
# CUSTOM PROJECT FILES
# ====================================================================
Readme_local.md
DEPLOY_CHECKLIST.md
PROJECT_PROGRESS.md
SMOKE_TEST_CHECKLIST.md